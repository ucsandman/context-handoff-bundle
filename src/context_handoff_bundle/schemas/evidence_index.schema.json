{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/context-handoff-bundle/evidence_index.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["path", "role", "used_for", "confidence", "review_status"],
    "properties": {
      "path": { "type": "string" },
      "role": { "type": "string" },
      "used_for": { "type": "array", "items": { "type": "string" } },
      "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
      "review_status": { "type": "string", "enum": ["reviewed", "referenced", "generated"] },
      "anchor_kind": { "type": "string", "enum": ["file", "url", "commit", "other"] },
      "resolved_path": { "type": ["string", "null"] },
      "line_start": { "type": ["integer", "null"] },
      "line_end": { "type": ["integer", "null"] },
      "content_hash": { "type": ["string", "null"] },
      "verified_at_save": { "type": "boolean" }
    }
  }
}
